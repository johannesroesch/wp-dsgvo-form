{
    "name": "wp-dsgvo-form",
    "version": "1.0.0",
    "description": "WordPress-Plugin for DSGVO-compliant forms with Gutenberg block",
    "private": true,
    "scripts": {
        "build": "wp-scripts build",
        "start": "wp-scripts start",
        "lint:js": "wp-scripts lint-js",
        "lint:css": "wp-scripts lint-style",
        "test:js": "wp-scripts test-unit-js",
        "i18n:pot": "wp i18n make-pot . languages/wp-dsgvo-form.pot --domain=wp-dsgvo-form --exclude=vendor,node_modules,build,tests",
        "i18n:mo": "wp i18n make-mo languages/",
        "i18n:json": "wp i18n make-json languages/ --no-purge",
        "i18n:build": "npm run i18n:pot && npm run i18n:mo && npm run i18n:json"
    },
    "overrides": {
        "adm-zip": "^0.6.0",
        "serialize-javascript": "^7.0.5",
        "minimatch": "^9.0.7",
        "uuid": "^11.1.1",
        "linkify-it": "^5.0.1",
        "markdown-it": "^14.2.0",
        "@babel/runtime": "^7.26.10",
        "@opentelemetry/core": "^2.8.0",
        "webpack-dev-server": "^5.2.6"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@wordpress/block-editor": "^16.0.0",
        "@wordpress/blocks": "^15.24.0",
        "@wordpress/components": "^28.0.0",
        "@wordpress/element": "^6.0.0",
        "@wordpress/i18n": "^5.0.0",
        "@wordpress/scripts": "^33.0.0"
    }
}
