<?xml version="1.0"?>
<ruleset name="WP DSGVO Form">
    <description>Coding standards for wp-dsgvo-form</description>

    <file>./includes</file>
    <file>./wp-dsgvo-form.php</file>
    <file>./uninstall.php</file>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>
    <exclude-pattern>build/*</exclude-pattern>
    <exclude-pattern>tests/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- WordPress Standards (Quality-Expert MUSS) -->
    <!-- WordPress-Extra includes Core + Security rules in WPCS 3.0 -->
    <rule ref="WordPress-Extra">
        <!-- Allow PSR-4 file naming for namespaced classes -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
    </rule>

    <!-- PHP Compatibility (Quality-Expert MUSS) -->
    <rule ref="PHPCompatibilityWP"/>
    <config name="testVersion" value="8.1-"/>
    <config name="minimum_wp_version" value="6.0"/>

    <!-- Text Domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="wp-dsgvo-form"/>
            </property>
        </properties>
    </rule>

    <!-- Custom Capabilities registered by this plugin (SEC-AUTH-01). -->
    <rule ref="WordPress.WP.Capabilities">
        <properties>
            <property name="custom_capabilities" type="array">
                <element value="dsgvo_form_manage"/>
                <element value="dsgvo_form_recipient"/>
                <element value="dsgvo_form_view_submissions"/>
                <element value="dsgvo_form_view_all_submissions"/>
                <element value="dsgvo_form_delete_submissions"/>
                <element value="dsgvo_form_export"/>
            </property>
        </properties>
    </rule>

    <!-- Encryption code legitimately uses base64 and json_encode (SEC-ENC). -->
    <rule ref="WordPress.PHP.DiscouragedPHPFunctions.obfuscation_base64_encode">
        <exclude-pattern>includes/Encryption/*</exclude-pattern>
        <exclude-pattern>includes/Upload/FileHandler.php</exclude-pattern>
    </rule>
    <rule ref="WordPress.PHP.DiscouragedPHPFunctions.obfuscation_base64_decode">
        <exclude-pattern>includes/Encryption/*</exclude-pattern>
        <exclude-pattern>includes/Upload/FileHandler.php</exclude-pattern>
    </rule>
    <rule ref="WordPress.WP.AlternativeFunctions.json_encode_json_encode">
        <exclude-pattern>includes/Encryption/*</exclude-pattern>
    </rule>

    <!--
        WordPress.DB.PreparedSQL: Table name interpolation is standard WP
        practice ($table = $wpdb->prefix . 'name'). WordPress provides no
        placeholder for table names. All SQL uses $wpdb->prepare() for
        user-supplied values (SEC-SQL-01).
    -->
    <rule ref="WordPress.DB.PreparedSQL.InterpolatedNotPrepared">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.DB.PreparedSQL.NotPrepared">
        <severity>0</severity>
    </rule>

    <!--
        WordPress.DB.PreparedSQLPlaceholders: Dynamic WHERE clauses built
        from validated %d/%s placeholders make the count unpredictable
        at static analysis time. All values are properly prepared.
    -->
    <rule ref="WordPress.DB.PreparedSQLPlaceholders.ReplacementsWrongNumber">
        <severity>0</severity>
    </rule>

    <!--
        Exception messages are not rendered as HTML output — they are caught
        and logged or displayed via wp_die() which handles escaping itself.
        Escaping inside throw statements would double-escape in error logs.
    -->
    <rule ref="WordPress.Security.EscapeOutput.ExceptionNotEscaped">
        <severity>0</severity>
    </rule>

    <!--
        Cyclomatic complexity: Raise absolute limit to 25 for complex but
        well-tested methods (form processing, DB schema creation).
        Warning threshold remains at 10 per Quality-Expert guidelines.
    -->
    <rule ref="Generic.Metrics.CyclomaticComplexity">
        <properties>
            <property name="complexity" value="10"/>
            <property name="absoluteComplexity" value="25"/>
        </properties>
    </rule>
    <rule ref="Generic.Metrics.NestingLevel">
        <properties>
            <property name="nestingLevel" value="4"/>
            <property name="absoluteNestingLevel" value="6"/>
        </properties>
    </rule>
</ruleset>
