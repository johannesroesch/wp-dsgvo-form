# wp-dsgvo-form Environment Configuration
# Copy this file to .env for local development
# NEVER commit .env with real values!

# Master encryption key (256-bit, base64-encoded)
# Generate with: php -r "echo base64_encode(random_bytes(32));"
DSGVO_FORM_MASTER_KEY=REPLACE_WITH_GENERATED_KEY

# WordPress test database (for integration tests)
WP_TESTS_DB_NAME=wordpress_test
WP_TESTS_DB_USER=root
WP_TESTS_DB_PASS=
WP_TESTS_DB_HOST=localhost
