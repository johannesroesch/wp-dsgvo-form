includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 6
    paths:
        - includes/
    excludePaths:
        - vendor/
        - includes/Cli/
    bootstrapFiles:
        - phpstan-bootstrap.php
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # WordPress API: add_submenu_page accepts null for hidden pages (undocumented but standard practice).
        -
            identifier: argument.type
            message: '#Parameter \#1 \$parent_slug of function add_submenu_page expects string, null given#'
        # WP_CLI is conditionally loaded — Plugin.php guards with defined('WP_CLI').
        -
            identifier: class.notFound
            message: '#unknown class WP_CLI#'
        # Bootstrap defines placeholder constants — comparison is always true in analysis but not in production.
        -
            identifier: notIdentical.alwaysTrue
            path: includes/Block/FormBlock.php
        # DI pattern: $access_control — @todo REFACTOR-01: needs_acknowledgment() auf Instanzmethode umstellen, dann $access_control nutzen.
        -
            identifier: property.onlyWritten
            path: includes/Admin/FirstLoginNotice.php
        # DI pattern: $audit_logger injected for DPO-SOLL-F07 (recipient change audit logging).
        -
            identifier: property.onlyWritten
            path: includes/Admin/RecipientListPage.php
