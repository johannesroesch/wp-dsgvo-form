{
    "name": "johannesroesch/wp-dsgvo-form",
    "description": "WordPress-Plugin for DSGVO-compliant forms with AES-256 encrypted storage",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "WpDsgvoForm\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpDsgvoForm\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "brain/monkey": "^2.7",
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpstan/phpstan": "^1.0"
    },
    "scripts": {
        "test": "phpunit --configuration tests/phpunit.xml",
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "analyze": "phpstan analyse includes/ --level=6",
        "i18n:pot": "wp i18n make-pot . languages/wp-dsgvo-form.pot --domain=wp-dsgvo-form --exclude=vendor,node_modules,build,tests",
        "i18n:mo": "wp i18n make-mo languages/",
        "i18n:build": "@i18n:pot && @i18n:mo"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
